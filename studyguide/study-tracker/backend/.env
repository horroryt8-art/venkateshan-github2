# Copy this file to .env, then fill in ONE of the two options below.
#
#   cp .env.example .env      (Mac/Linux)
#   copy .env.example .env    (Windows)

# ---------------------------------------------------------------
# OPTION A — MongoDB Atlas (free cloud database, recommended)
# ---------------------------------------------------------------
# 1. Create a free cluster at https://mongodb.com/cloud/atlas/register
# 2. Database Access -> add a database user (username + password)
# 3. Network Access -> allow access from anywhere (0.0.0.0/0) to get
#    started quickly
# 4. Cluster -> Connect -> Drivers -> Node.js -> copy the connection
#    string it gives you and paste it below, replacing <username> and
#    <password> with your actual credentials, and adding a database
#    name ("studytracker") right after ".net/"
#
# Example (yours will have a different cluster address):
# MONGO_URI=mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/studytracker?retryWrites=true&w=majority

# ---------------------------------------------------------------
# OPTION B — local MongoDB install
# ---------------------------------------------------------------
# Only use this if you have MongoDB Community Server running on your
# own machine. This is the default below.
MONGO_URI=mongodb://doctordooom57_db_user:venki2005@ac-zfs01zy-shard-00-00.hcqaqmi.mongodb.net:27017,ac-zfs01zy-shard-00-01.hcqaqmi.mongodb.net:27017,ac-zfs01zy-shard-00-02.hcqaqmi.mongodb.net:27017/?ssl=true&replicaSet=atlas-9ta4ez-shard-0&authSource=admin&appName=Cluster0

# ---------------------------------------------------------------
PORT=5000
